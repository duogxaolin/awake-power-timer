# Maintainer: duogxaolin <duogxaolin@gmail.com>
# Checksums are set to SKIP because the package downloads release binaries from GitHub.
# A proper PKGBUILD for an official AUR submission should fetch the upstream source
# tarball and update the checksums accordingly.
pkgname=awake-power-timer-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Cross-platform desktop app to keep your system awake and schedule power actions"
arch=('x86_64' 'aarch64')
url="https://github.com/duogxaolin/awake-power-timer"
license=('MIT')
depends=('gtk3' 'webkit2gtk-4.1' 'libappindicator-gtk3' 'libsoup-3.0' 'glib2' 'cairo' 'pango' 'gdk-pixbuf2' 'openssl' 'gcc-libs')
optdepends=('libnotify: desktop notifications')
provides=('awake-power-timer')
conflicts=('awake-power-timer')
options=(!strip !debug)
source_x86_64=("${url}/releases/download/v${pkgver}/awake-power-timer_${pkgver}_amd64.deb")
source_aarch64=("${url}/releases/download/v${pkgver}/awake-power-timer_${pkgver}_arm64.deb")
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
  tar -xvf data.tar.gz -C "${pkgdir}"
  install -Dm644 "${pkgdir}/usr/share/applications/awake-power-timer.desktop" \
    "${pkgdir}/usr/share/applications/awake-power-timer.desktop"
  install -Dm644 "${pkgdir}/usr/share/icons/hicolor/256x256@2/apps/awake-power-timer.png" \
    "${pkgdir}/usr/share/icons/hicolor/256x256@2/apps/awake-power-timer.png"
  install -Dm644 "${pkgdir}/usr/share/icons/hicolor/128x128/apps/awake-power-timer.png" \
    "${pkgdir}/usr/share/icons/hicolor/128x128/apps/awake-power-timer.png"
  install -Dm644 "${pkgdir}/usr/share/icons/hicolor/32x32/apps/awake-power-timer.png" \
    "${pkgdir}/usr/share/icons/hicolor/32x32/apps/awake-power-timer.png"
  install -Dm644 "${startdir}/../LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
